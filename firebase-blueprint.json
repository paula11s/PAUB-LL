{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "isAnonymous": { "type": "boolean" }
      },
      "required": ["uid", "createdAt", "updatedAt", "isAnonymous"]
    },
    "Plan": {
      "title": "Plan",
      "description": "A daily plan generated by the AI",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "energia": { "type": "string" },
        "animo": { "type": "string" },
        "prompt": { "type": "string" },
        "data": { "type": "object" },
        "completedTasks": {
          "type": "array",
          "items": { "type": "number" }
        },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["userId", "energia", "animo", "prompt", "data", "completedTasks", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles"
    },
    "/users/{userId}/plans/{planId}": {
      "schema": { "$ref": "#/entities/Plan" },
      "description": "Stores plans generated for the user"
    }
  }
}
