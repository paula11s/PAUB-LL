rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic global security helper
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // USER VALIDATORS
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'createdAt', 'updatedAt', 'isAnonymous', 'email', 'career']) &&
             data.uid == request.auth.uid &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp &&
             data.isAnonymous is bool;
    }

    // PLAN VALIDATORS
    function isValidPlan(data) {
      return data.keys().hasAll(['userId', 'energia', 'animo', 'prompt', 'data', 'completedTasks', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 8 &&
             data.userId == request.auth.uid &&
             data.energia is string && data.energia.size() <= 50 &&
             data.animo is string && data.animo.size() <= 50 &&
             data.prompt is string && data.prompt.size() <= 5000 &&
             data.data is map &&
             data.completedTasks is list && data.completedTasks.size() <= 100 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    // ALARM VALIDATORS
    function isValidAlarm(data) {
      return data.keys().hasAll(['userId', 'time', 'title', 'enabled', 'type', 'createdAt', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.time is string && data.time.size() <= 10 &&
             data.title is string && data.title.size() <= 100 &&
             data.enabled is bool &&
             data.type is string && data.type.size() <= 20 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    // CLASS VALIDATORS
    function isValidClass(data) {
      return data.keys().hasAll(['userId', 'day', 'time', 'subject', 'materials', 'createdAt', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.day is string && data.day.size() <= 20 &&
             data.time is string && data.time.size() <= 20 &&
             data.subject is string && data.subject.size() <= 100 &&
             data.materials is list && data.materials.size() <= 50 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    // CALENDAR TASK VALIDATORS
    function isValidCalendarTask(data) {
      return data.keys().hasAll(['userId', 'date', 'title', 'completed', 'createdAt', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.date is timestamp &&
             data.title is string && data.title.size() <= 200 &&
             data.completed is bool &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    // PROJECTS VALIDATORS
    function isValidProject(data) {
      return data.keys().hasAll(['userId', 'title', 'progress', 'isComplete', 'rewardOutfitId', 'createdAt', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() <= 200 &&
             data.progress is number &&
             data.isComplete is bool &&
             data.rewardOutfitId is string && data.rewardOutfitId.size() <= 50 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    // Fallback: deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if false; // Users cannot list other users
      
      allow create: if isSignedIn() &&
                       isValidId(userId) &&
                       userId == request.auth.uid &&
                       isValidUser(incoming()) &&
                       incoming().createdAt == request.time &&
                       incoming().updatedAt == request.time;
                       
      allow update: if isSignedIn() &&
                       isValidId(userId) &&
                       userId == request.auth.uid &&
                       isValidUser(incoming()) &&
                       incoming().uid == existing().uid &&
                       incoming().createdAt == existing().createdAt &&
                       incoming().updatedAt == request.time &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['updatedAt', 'isAnonymous', 'career', 'email', 'outfit', 'unlockedOutfits']);
                       
      allow delete: if isSignedIn() && request.auth.uid == userId;

      match /plans/{planId} {
        allow get: if isSignedIn() && request.auth.uid == userId;
        allow list: if isSignedIn() && request.auth.uid == userId;

        allow create: if isSignedIn() &&
                         isValidId(userId) && isValidId(planId) &&
                         userId == request.auth.uid &&
                         isValidPlan(incoming()) &&
                         incoming().createdAt == request.time &&
                         incoming().updatedAt == request.time &&
                         exists(/databases/$(database)/documents/users/$(request.auth.uid));
                         
        allow update: if isSignedIn() &&
                         isValidId(userId) && isValidId(planId) &&
                         userId == request.auth.uid &&
                         isValidPlan(incoming()) &&
                         incoming().userId == existing().userId &&
                         incoming().createdAt == existing().createdAt &&
                         incoming().updatedAt == request.time &&
                         // Allow updating completedTasks and updatedAt only
                         incoming().diff(existing()).affectedKeys().hasOnly(['completedTasks', 'updatedAt']);
                         
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /alarms/{alarmId} {
        allow get, list: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && isValidId(userId) && isValidId(alarmId) &&
                         userId == request.auth.uid && isValidAlarm(incoming()) &&
                         incoming().createdAt == request.time && incoming().updatedAt == request.time &&
                         exists(/databases/$(database)/documents/users/$(request.auth.uid));
        allow update: if isSignedIn() && isValidId(userId) && isValidId(alarmId) &&
                         userId == request.auth.uid && isValidAlarm(incoming()) &&
                         incoming().userId == existing().userId &&
                         incoming().createdAt == existing().createdAt &&
                         incoming().updatedAt == request.time &&
                         incoming().diff(existing()).affectedKeys().hasOnly(['title', 'time', 'enabled', 'type', 'updatedAt']);
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /classes/{classId} {
        allow get, list: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && isValidId(userId) && isValidId(classId) &&
                         userId == request.auth.uid && isValidClass(incoming()) &&
                         incoming().createdAt == request.time && incoming().updatedAt == request.time &&
                         exists(/databases/$(database)/documents/users/$(request.auth.uid));
        allow update: if isSignedIn() && isValidId(userId) && isValidId(classId) &&
                         userId == request.auth.uid && isValidClass(incoming()) &&
                         incoming().userId == existing().userId &&
                         incoming().createdAt == existing().createdAt &&
                         incoming().updatedAt == request.time &&
                         incoming().diff(existing()).affectedKeys().hasOnly(['day', 'time', 'subject', 'materials', 'updatedAt']);
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /calendarTasks/{taskId} {
        allow get, list: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && isValidId(userId) && isValidId(taskId) &&
                         userId == request.auth.uid && isValidCalendarTask(incoming()) &&
                         incoming().createdAt == request.time && incoming().updatedAt == request.time &&
                         exists(/databases/$(database)/documents/users/$(request.auth.uid));
        allow update: if isSignedIn() && isValidId(userId) && isValidId(taskId) &&
                         userId == request.auth.uid && isValidCalendarTask(incoming()) &&
                         incoming().userId == existing().userId &&
                         incoming().createdAt == existing().createdAt &&
                         incoming().updatedAt == request.time &&
                         incoming().diff(existing()).affectedKeys().hasOnly(['title', 'completed', 'date', 'updatedAt']);
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }
      match /projects/{projectId} {
        allow get, list: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && isValidId(userId) && isValidId(projectId) &&
                         userId == request.auth.uid && isValidProject(incoming()) &&
                         incoming().createdAt == request.time && incoming().updatedAt == request.time &&
                         exists(/databases/$(database)/documents/users/$(request.auth.uid));
        allow update: if isSignedIn() && isValidId(userId) && isValidId(projectId) &&
                         userId == request.auth.uid && isValidProject(incoming()) &&
                         incoming().userId == existing().userId &&
                         incoming().createdAt == existing().createdAt &&
                         incoming().updatedAt == request.time &&
                         incoming().diff(existing()).affectedKeys().hasOnly(['title', 'progress', 'isComplete', 'rewardOutfitId', 'updatedAt']);
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /messages/{messageId} {
        allow get, list: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && isValidId(userId) && isValidId(messageId) &&
                         userId == request.auth.uid && 
                         incoming().keys().hasAny(['role', 'text', 'createdAt', 'mood', 'userId']) &&
                         incoming().role is string && incoming().text is string &&
                         incoming().createdAt == request.time &&
                         exists(/databases/$(database)/documents/users/$(request.auth.uid));
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /finals/{finalId} {
        allow get, list: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && isValidId(userId) && isValidId(finalId) && userId == request.auth.uid;
        allow update: if isSignedIn() && isValidId(userId) && isValidId(finalId) && userId == request.auth.uid;
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}
