rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic global security helper
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // USER VALIDATORS
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'createdAt', 'updatedAt', 'isAnonymous']) &&
             data.keys().size() == 4 &&
             data.uid == request.auth.uid &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp &&
             data.isAnonymous is bool;
    }

    // PLAN VALIDATORS
    function isValidPlan(data) {
      return data.keys().hasAll(['userId', 'energia', 'animo', 'prompt', 'data', 'completedTasks', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 8 &&
             data.userId == request.auth.uid &&
             data.energia is string && data.energia.size() <= 50 &&
             data.animo is string && data.animo.size() <= 50 &&
             data.prompt is string && data.prompt.size() <= 5000 &&
             data.data is map &&
             data.completedTasks is list && data.completedTasks.size() <= 100 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    // Fallback: deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if false; // Users cannot list other users
      
      allow create: if isSignedIn() &&
                       isValidId(userId) &&
                       userId == request.auth.uid &&
                       isValidUser(incoming()) &&
                       incoming().createdAt == request.time &&
                       incoming().updatedAt == request.time;
                       
      allow update: if isSignedIn() &&
                       isValidId(userId) &&
                       userId == request.auth.uid &&
                       isValidUser(incoming()) &&
                       incoming().uid == existing().uid &&
                       incoming().createdAt == existing().createdAt &&
                       incoming().updatedAt == request.time &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['updatedAt', 'isAnonymous']);
                       
      allow delete: if isSignedIn() && request.auth.uid == userId;

      match /plans/{planId} {
        allow get: if isSignedIn() && request.auth.uid == userId;
        allow list: if isSignedIn() && request.auth.uid == userId;

        allow create: if isSignedIn() &&
                         isValidId(userId) && isValidId(planId) &&
                         userId == request.auth.uid &&
                         isValidPlan(incoming()) &&
                         incoming().createdAt == request.time &&
                         incoming().updatedAt == request.time &&
                         exists(/databases/$(database)/documents/users/$(request.auth.uid));
                         
        allow update: if isSignedIn() &&
                         isValidId(userId) && isValidId(planId) &&
                         userId == request.auth.uid &&
                         isValidPlan(incoming()) &&
                         incoming().userId == existing().userId &&
                         incoming().createdAt == existing().createdAt &&
                         incoming().updatedAt == request.time &&
                         // Allow updating completedTasks and updatedAt only
                         incoming().diff(existing()).affectedKeys().hasOnly(['completedTasks', 'updatedAt']);
                         
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}
